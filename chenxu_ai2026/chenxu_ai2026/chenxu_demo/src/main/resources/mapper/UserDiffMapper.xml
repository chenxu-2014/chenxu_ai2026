<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.datacompare.mapper.UserDiffMapper">

    <resultMap id="BaseResultMap" type="org.example.datacompare.entity.UserDiffResult">
        <id     column="id"         property="id"/>
        <result column="batch_id"   property="batchId"/>
        <result column="user_id"    property="userId"/>
        <result column="diff_type"  property="diffType"/>
        <result column="field_name" property="fieldName"/>
        <result column="value_a"    property="valueA"/>
        <result column="value_b"    property="valueB"/>
        <result column="diff_time"  property="diffTime"/>
    </resultMap>

    <insert id="insertBatch" parameterType="list">
        INSERT INTO c_user_diff (batch_id, user_id, diff_type, field_name, value_a, value_b, diff_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.batchId}, #{item.userId}, #{item.diffType},
             #{item.fieldName}, #{item.valueA}, #{item.valueB}, NOW())
        </foreach>
    </insert>

    <select id="countByBatchId" resultType="long">
        SELECT COUNT(*) FROM c_user_diff WHERE batch_id = #{batchId}
    </select>

    <select id="selectByBatchId" resultMap="BaseResultMap">
        SELECT id, batch_id, user_id, diff_type, field_name, value_a, value_b, diff_time
        FROM c_user_diff
        WHERE batch_id = #{batchId}
        ORDER BY id
    </select>

    <delete id="deleteByBatchId">
        DELETE FROM c_user_diff WHERE batch_id = #{batchId}
    </delete>

</mapper>
